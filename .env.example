# ─────────────────────────────────────────────────────────────────────────
# exif-photo-blog — environment (PLOG-12). Copy to .env.local and fill in.
# Grouped by feature. NEXT_PUBLIC_* are exposed to the browser.
# ─────────────────────────────────────────────────────────────────────────

# ── Database (Postgres / Supabase) ── REQUIRED ───────────────────────────
# Pooled connection string (sslmode is stripped; SSL handled in pg.Pool).
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
# Set to 1 only for a local non-SSL Postgres.
# DISABLE_POSTGRES_SSL=

# ── Auth (admin) ── REQUIRED ─────────────────────────────────────────────
ADMIN_EMAIL=
ADMIN_PASSWORD=
AUTH_SECRET=                       # `openssl rand -base64 32`

# ── AI metadata generation ──────────────────────────────────────────────
# Preferred: Vercel AI Gateway. Set a CURRENT catalog model id (verify live;
# never hardcode a stale one) — e.g. openai/gpt-4o, google/gemini-2.5-flash.
AI_GATEWAY_API_KEY=
AI_MODEL=openai/gpt-4o
AI_MODEL_FALLBACK=
# Legacy escape hatch: direct OpenAI (or any OpenAI-compatible base URL).
# OPENAI_SECRET_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=
# AI_TEXT_AUTO_GENERATED_FIELDS=title,tags,semantic
# AI_PROMPT_VERSION=v1              # bump to force a backfill re-run
# AI_BACKFILL_CONCURRENCY=5

# ── Storage (pick ONE backend) ───────────────────────────────────────────
# Cloudflare R2 (primary; image loader serves variants from the public domain)
NEXT_PUBLIC_CLOUDFLARE_R2_BUCKET=
NEXT_PUBLIC_CLOUDFLARE_R2_ACCOUNT_ID=
NEXT_PUBLIC_CLOUDFLARE_R2_PUBLIC_DOMAIN=     # e.g. photos.example.com
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
# Vercel Blob:  BLOB_READ_WRITE_TOKEN=
# AWS S3:       NEXT_PUBLIC_AWS_S3_BUCKET= NEXT_PUBLIC_AWS_S3_REGION= AWS_S3_ACCESS_KEY= AWS_S3_SECRET_ACCESS_KEY=
# MinIO:        NEXT_PUBLIC_MINIO_BUCKET= NEXT_PUBLIC_MINIO_DOMAIN= NEXT_PUBLIC_MINIO_PORT= MINIO_ACCESS_KEY= MINIO_SECRET_ACCESS_KEY=

# ── Cache / rate-limit (optional — Redis/Upstash KV) ─────────────────────
# Redis is CACHE/RATE-LIMIT ONLY (not the database). Unset → feature dormant.
# KV_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# ── Site identity / meta ─────────────────────────────────────────────────
NEXT_PUBLIC_DOMAIN=
NEXT_PUBLIC_META_TITLE=            # was NEXT_PUBLIC_SITE_TITLE (deprecated)
NEXT_PUBLIC_META_DESCRIPTION=
# NEXT_PUBLIC_NAV_TITLE=
# NEXT_PUBLIC_LOCALE=en-us

# ── Misc / integrations (optional) ───────────────────────────────────────
# GOOGLE_PLACES_API_KEY=            # reverse-geocode upload locations
# NEXT_PUBLIC_IMAGE_QUALITY=75

# ── Feature flags (optional; see src/app/config.ts for the full set) ─────
# The app exposes many NEXT_PUBLIC_* toggles (grid style, color sort, category
# visibility, OG layout, etc.). All default sensibly; set only to override.
